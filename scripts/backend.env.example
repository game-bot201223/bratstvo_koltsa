GAME_DB_DSN=dbname=gamedb user=postgres host=/var/run/postgresql
TELEGRAM_BOT_TOKEN=REPLACE_WITH_REAL_BOT_TOKEN
ADMIN_TG_IDS=REPLACE_WITH_ADMIN_TG_ID
# Экстренное отключение анти-вайпа state (не включать в проде без причины):
# DISABLE_STATE_WIPE_GUARD=1
# Отключение max-merge прогресса с БД (не включать без причины):
# DISABLE_PROGRESSION_MAX_MERGE=1
# Отключить stdout-логи PLAYER_PROGRESS ... (journald/docker):
# DISABLE_PLAYER_PROGRESS_LOG=1
# Автоснимок полного профиля в admin_player_snapshots каждые N успешных state_version (0 = выкл):
# AUTO_PLAYER_SNAPSHOT_EVERY_SV=25
# Снимок каждые N записей в player_state_events (Redis INCR; при недоступности Redis — fallback по state_version % N):
# AUTO_PLAYER_SNAPSHOT_EVERY_N_EVENTS=50
# Потолок валюты при серверном начислении (босс и т.д.), как на клиенте:
# PLAYER_CURRENCY_CAP=999999999999
# Автоснимок по времени, не реже чем раз в N минут (0 = выкл), note=AUTO_CHECKPOINT_T:
# AUTO_PLAYER_SNAPSHOT_MINUTES=120
# Запрет полного state от клиента (upsert/realtime_save/state в boss_hit save). Снять только для миграции:
# ALLOW_CLIENT_FULL_STATE_SAVE=1
# Не писать activity_log (клан/босс/session/sync_pull/...) в player_state_events:
# DISABLE_PLAYER_ACTIVITY_LOG=1
# Проверка структуры state перед записью (null / неверный тип известных полей):
# DISABLE_STATE_INTEGRITY_CHECK=1
# Защита от резкого падения «оценки прогресса» (доп. к анти-вайпу):
# DISABLE_SHARP_DEGRADATION_GUARD=1
# Пороги sharp-guard (опционально): SHARP_GUARD_MIN_EXISTING_SCORE, SHARP_GUARD_SCORE_RATIO, SHARP_GUARD_MAX_CORE_DROP
# Не писать строки в player_state_events (журнал сохранений):
# DISABLE_PLAYER_STATE_EVENTS=1
# Лимит успешных попыток сохранения state в минуту на игрока (Redis; 0 = выкл):
# SAVE_RATE_LIMIT_PER_MINUTE_TG=180
# Опционально лимит по IP (за прокси нужен корректный X-Forwarded-For):
# SAVE_RATE_LIMIT_PER_MINUTE_IP=600
# Требовать session_id в теле save = players.active_session_id (после включения клиент шлёт session_id с v29):
# REQUIRE_SESSION_MATCH_FOR_SAVE=1
# Игровые RPC без full-state: POST /functions/v1/player_game_action_v1 (лавка, арена, расходники, ГБ — см. PLAYER_DATA_PROTECTION.md)
#
# Групповой бой: серверный battle — docs/GROUP_FIGHT_SERVER_STATE.md
# GF_SERVER_BATTLE_PRIMARY=1
# Алиасы Фазы 1 (create_gf_session_v1 / gf_action_v1 / gf_commit_v1); без флага новые имена → 403:
# GF_SERVER_ACTIONS_ENABLED=1
# Тест: фиксированный id расходника (1..10) в gf_commit_v1 вместо RNG:
# GF_COMMIT_TEST_DROP_ID=7
